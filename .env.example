# העתק ל-.env (gitignored) ומלא ערכים.


# PayPlus checkout — URLs ציבוריים של Cloud Functions (לא מפתחות PayPlus!)
VITE_CHARGE_VANTIX_ORDER_URL=https://us-central1-maxdeliveries.cloudfunctions.net/chargeVantixOrder
VITE_TOKENIZE_VANTIX_CARD_URL=https://us-central1-maxdeliveries.cloudfunctions.net/tokenizeVantixCustomerCard
# Google Pay / Apple Pay — לינק PayPlus (דורש PAYPLUS_PAYMENT_PAGE_UID בשרת)
VITE_WALLET_VANTIX_CHECKOUT_URL=https://us-central1-maxdeliveries.cloudfunctions.net/startVantixWalletCheckout
VITE_QUOTE_VANTIX_DELIVERY_URL=https://us-central1-maxdeliveries.cloudfunctions.net/quoteVantixDeliveryFee

# (אופציונלי) Payment Request API מקומי — לא בשימוש כרגע; התשלום עובר דרך דף PayPlus
